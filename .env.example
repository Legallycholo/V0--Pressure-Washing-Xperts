# Public site URL (no trailing slash) — used for canonical URLs, sitemap, robots, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Voiceflow chat widget — IDs from Voiceflow → Share / Embed (version can be production or a version ID).
NEXT_PUBLIC_VOICEFLOW_PROJECT_ID=69dd9d010f5914da645bf6d0
NEXT_PUBLIC_VOICEFLOW_VERSION_ID=69dd9d010f5914da645bf6d1
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Use one of the two options below:
# - Recommended (new projects): publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
# - Legacy compatibility: anon JWT key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_key_here

# Optional (server only — never expose to the browser). If set, lead inserts use the
# service role so rows reach `public.leads` even if RLS policies are misconfigured.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
